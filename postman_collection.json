{
  "info": {
    "name": "Pocketful KYC API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/health",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "2. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"SecurePass123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/register",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "register"
          ]
        }
      }
    },
    {
      "name": "3. Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"user_token\", jsonData.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"SecurePass123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "4. Initiate KYC",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{user_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/kyc/initiate",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "kyc",
            "initiate"
          ]
        }
      }
    },
    {
      "name": "5. Upload PAN",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{user_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "doc_type",
              "value": "PAN",
              "type": "text"
            },
            {
              "key": "pan_number",
              "value": "ABCDE1234F",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "http://localhost:8080/kyc/upload",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "kyc",
            "upload"
          ]
        }
      }
    },
    {
      "name": "6. Check KYC Status",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{user_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/kyc/status",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "kyc",
            "status"
          ]
        }
      }
    },
    {
      "name": "7. Login Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"admin_token\", jsonData.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@pocketful.com\",\n  \"password\": \"Admin@12345\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/login",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "login"
          ]
        }
      }
    },
    {
      "name": "8. Verify KYC (Admin)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{admin_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"kyc_id\": \"PASTE_KYC_ID_HERE\",\n  \"action\": \"APPROVE\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/admin/verify",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "admin",
            "verify"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "user_token",
      "value": ""
    },
    {
      "key": "admin_token",
      "value": ""
    }
  ]
}
